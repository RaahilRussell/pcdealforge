# PCDealForge environment configuration
# Copy to .env and fill in the values you have. No key is required — the app uses
# whatever retailer adapters are configured and reports the rest as unavailable.

DATABASE_URL="file:./dev.db"

# ---- Live Link Mode (default) ----
# LIVE_LINK_MODE=true (default) generates real retailer search/buy links for every part and
# verifies prices best-effort from public pages. No API keys required.
LIVE_LINK_MODE=true
# DEMO_MODE=true forces seeded demo data (tests/offline dev only). Default off.
DEMO_MODE=false
# LIVE_RETAILER_MODE=true additionally enables key-based retailer API adapters (optional upgrade).
LIVE_RETAILER_MODE=false

# ---- Retailer credentials (all optional) ----
# Best Buy Products API (official_api)
BESTBUY_API_KEY=

# eBay Browse API (official_api) — OAuth client credentials
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# Amazon Creators API / affiliate (affiliate_api) — both required to enable
AMAZON_CREATOR_API_KEY=
AMAZON_PARTNER_TAG=

# Micro Center (manual_verified) — location aware; no compliant public API today
MICROCENTER_LOCATION_ID=

# Newegg partner feed (partner_feed)
NEWEGG_PARTNER_KEY=
