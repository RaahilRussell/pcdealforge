// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Product {
  id             String   @id @default(cuid())
  category       String
  brand          String
  model          String
  normalizedName String
  mpn            String?
  upc            String?
  specsJson      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  offers        Offer[]
  priceSnapshots PriceSnapshot[]
  dailyPrices   DailyProductPrice[]

  @@index([category])
  @@index([normalizedName])
  @@index([mpn])
  @@index([upc])
}

model Offer {
  id              String   @id @default(cuid())
  productId       String
  retailer        String
  title           String
  url             String
  price           Float
  shipping        Float
  taxEstimate     Float
  condition       String
  sellerName      String?
  sellerRating    Float?
  inStock         Boolean
  confidenceScore Float
  lastCheckedAt   DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product        Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  priceSnapshots PriceSnapshot[]

  @@index([productId])
  @@index([retailer])
  @@index([condition])
  @@index([inStock])
}

model PriceSnapshot {
  id            String   @id @default(cuid())
  productId     String
  offerId       String?
  retailer      String
  price         Float
  shipping      Float
  taxEstimate   Float
  condition     String
  inStock       Boolean
  sellerName    String?
  sellerRating  Float?
  timestamp     DateTime

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  offer   Offer?  @relation(fields: [offerId], references: [id], onDelete: SetNull)

  @@index([productId, timestamp])
  @@index([offerId])
  @@index([retailer])
}

model DailyProductPrice {
  id                 String   @id @default(cuid())
  productId          String
  date               DateTime
  minNewPrice        Float
  minOpenBoxPrice    Float?
  avgNewPrice        Float
  lowestTrustedPrice Float
  retailerCount      Int

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, date])
  @@index([date])
}

model SavedBuild {
  id                  String   @id @default(cuid())
  name                String
  targetBudget        Float
  useCase             String
  resolution          String
  partsJson           String
  totalPrice          Float
  compatibilityStatus String
  dealScore           Float
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([targetBudget])
  @@index([useCase])
  @@index([compatibilityStatus])
}

model EvidenceSource {
  id              String   @id @default(cuid())
  sourceType      String
  title           String
  publisher       String
  url             String?
  capturedAt      DateTime
  confidenceScore Float
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([sourceType])
}

model ProductEvidence {
  id               String   @id @default(cuid())
  productId        String
  evidenceSourceId String
  claimType        String
  claim            String
  value            String
  unit             String?
  createdAt        DateTime @default(now())

  @@index([productId])
  @@index([claimType])
  @@index([evidenceSourceId])
}

model BuildEvidence {
  id               String   @id @default(cuid())
  savedBuildId     String?
  evidenceSourceId String
  claimType        String
  claim            String
  createdAt        DateTime @default(now())

  @@index([savedBuildId])
  @@index([claimType])
  @@index([evidenceSourceId])
}
